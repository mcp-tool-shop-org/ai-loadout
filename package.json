{
  "name": "@mcptoolshop/ai-loadout",
  "version": "1.2.0",
  "description": "Context-aware knowledge router for AI agents. Dispatch table, matcher, usage tracking, dead/overlap analysis, budget CLI.",
  "type": "module",
  "bin": {
    "ai-loadout": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "verify": "tsc --noEmit && node --test dist/tests/*.test.js",
    "test": "node --test dist/tests/*.test.js",
    "test:coverage": "c8 --reporter=lcov --reporter=text node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "SPEC.md",
    "LICENSE",
    "SECURITY.md",
    "logo.png"
  ],
  "keywords": [
    "ai",
    "agent",
    "loadout",
    "knowledge",
    "routing",
    "dispatch",
    "context",
    "frontmatter",
    "mcp"
  ],
  "author": "mcp-tool-shop",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "typescript": "^5.7.0"
  }
}
